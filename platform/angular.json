{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "platform": {
      "projectType": "application",
      "root": "",
      "sourceRoot": "client",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "outputPath": {
              "base": "dist/client",
              "browser": "browser",
              "server": "server"
            },
            "index": "index.html",
            "browser": "client/main.ts",
            "server": "client/main.server.ts",
            "polyfills": [
              "zone.js"
            ],
            "tsConfig": "tsconfig.json",
            "assets": [
              {
                "glob": "**/*",
                "input": "client/assets/images",
                "output": "assets/images"
              }
            ],
            "styles": [
              "client/assets/css/styles.built.css"
            ],
            "scripts": [],
            "prerender": false,
            "ssr": {
              "entry": "client/server.ts"
            }
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "500kB",
                  "maximumError": "1MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "4kB",
                  "maximumError": "8kB"
                }
              ],
              "outputHashing": "all",
              "optimization": true
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true,
              "outputHashing": "none"
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "platform:build:production"
            },
            "development": {
              "buildTarget": "platform:build:development",
              "proxyConfig": "client/proxy.conf.json"
            }
          },
          "defaultConfiguration": "development"
        }
      }
    }
  }
}