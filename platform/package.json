{
  "name": "projetct-platform",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "start:dev": "nest start --watch",
    "start:dev:client": "ng serve",
    "start:dev:prediction": "cd prediction-service && uvicorn main:app --reload --port 8001",
    "dev:services": "docker compose -f docker-compose.dev.yml up -d",
    "dev": "concurrently \"npm run start:dev\" \"npm run start:dev:client\" \"npm run start:dev:prediction\"",
    "build": "node build-css.js && nest build && ng build",
    "build:client": "ng build",
    "start": "NODE_ENV=production node dist/main",
    "lint": "eslint \"{src,client}/**/*.ts\" --fix",
    "test": "jest"
  },
  "dependencies": {
    "@angular/animations": "^21.0.0",
    "@angular/common": "^21.0.0",
    "@angular/compiler": "^21.0.0",
    "@angular/core": "^21.0.0",
    "@angular/forms": "^21.0.0",
    "@angular/platform-browser": "^21.0.0",
    "@angular/platform-server": "^21.0.0",
    "@angular/router": "^21.0.0",
    "@angular/ssr": "^21.0.0",
    "@keyv/redis": "^4.3.3",
    "@nestjs/cache-manager": "^2.3.0",
    "@nestjs/common": "^10.4.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/platform-express": "^10.4.0",
    "@nestjs/typeorm": "^10.0.2",
    "cache-manager": "^5.7.6",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^16.4.5",
    "flowbite": "^4.0.2",
    "keyv": "^5.2.3",
    "pg": "^8.12.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.20",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular/build": "^21.0.0",
    "@angular/cli": "^21.0.0",
    "@angular/compiler-cli": "^21.0.0",
    "@nestjs/cli": "^10.4.0",
    "@nestjs/schematics": "^10.1.0",
    "@nestjs/testing": "^10.4.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "concurrently": "^9.0.1",
    "tailwind-merge": "^2.5.0",
    "tailwindcss": "^4.0.0",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.0"
  }
}
